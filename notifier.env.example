# notifier.env — the attention-notifier's secrets env-file (deployment spec §4).
#
# Copy to ${OMEGAHIVE_SECRETS_DIR}/notifier.env (that dir is 0700; this file 0600) and fill
# in the real values THERE — never here, never anywhere in the repo tree. Names are declared
# in secrets-manifest.yaml (notifier row); the credential scan hard-fails on anything beyond.
#
#   install -m600 /dev/null "$OMEGAHIVE_SECRETS_DIR/notifier.env"   # then edit it
#
# The compose `notifier` service loads this file plus .env (for the DB DSN / read path).

# Bot token from BotFather (message @BotFather -> /newbot -> follow prompts). The notifier is
# OUTBOUND ONLY: it never calls getUpdates and has no webhook, so the token is used solely to
# POST sendMessage. NEVER commit the real value.
TELEGRAM_BOT_TOKEN=

# Destination chat id (your 1:1 chat with the bot, or a group/channel the bot is in). To find
# it: send the bot any message, then GET https://api.telegram.org/bot<token>/getUpdates and
# read result[].message.chat.id. Config, not a secret — but it lives here for one-file setup.
TELEGRAM_CHAT_ID=

# Optional: override the Telegram API base (default https://api.telegram.org). For a self-host
# or a test double only; leave unset in production.
# TELEGRAM_API_BASE=https://api.telegram.org
