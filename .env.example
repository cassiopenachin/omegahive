# Copy to .env before `docker compose up`. Secrets live only here (deployment spec §4).
# Hosts are the compose service name `postgres` (containers talk over the compose network).
OMEGAHIVE_DATABASE_URL=postgresql://omegahive:omegahive@postgres:5432/omegahive
OMEGAHIVE_TEST_DATABASE_URL=postgresql://omegahive:omegahive@postgres:5432/omegahive_test
# The acceptance run id (seed, actors, and board-view must share it).
OMEGAHIVE_RUN_ID=accept

# Backups (deployment spec §5). OMEGAHIVE_BACKUP_DIR is the HOST directory the `backup`
# service bind-mounts at /backups — where pg_dumps AND workspace git bundles land so one
# directory restores both stores, and where the operator rsyncs from over the tailnet.
# In production the systemd timer sets it (Environment=), so it need not live in .env; set
# it here only for manual `compose --profile ops run --rm backup`. Absolute path, outside
# the repo tree. OMEGAHIVE_BACKUP_KEEP bounds how many dumps/bundles are retained.
#OMEGAHIVE_BACKUP_DIR=/home/<deployuser>/omegahive-backups
OMEGAHIVE_BACKUP_KEEP=14

# Provider API keys for the R1 LLM coordinator (ladder) do NOT go here. `.env` is shared by
# every compose service including `deploy-checks`, whose credential scan (stage2 §5.2) must
# stay key-free. Keep the key in the host shell and let the `ladder` service pass it through:
#   OPENROUTER_API_KEY=… docker compose run --rm ladder smoke --model openrouter/<model>
# (ANTHROPIC_API_KEY works the same for anthropic/<model>.)
